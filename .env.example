# Runtime mode
NODE_ENV=production

# Public server binding
HOST=0.0.0.0
PORT=3003

# Public site origin
APP_ORIGIN=https://guandan.example.com

# Optional custom Socket.IO origin list
SOCKET_CORS_ORIGINS=https://guandan.example.com

# Leave empty for same-origin production deployments
# NEXT_PUBLIC_SOCKET_URL=

# Lobby lifecycle
RECONNECT_GRACE_MS=30000
ROOM_IDLE_TTL_MS=900000

# Room entry burst protection
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_MAX=10
